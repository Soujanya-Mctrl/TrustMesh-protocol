{
  "name": "trustmesh",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "scripts": {
    "build": "hardhat build",
    "clean": "hardhat clean",
    "compile": "hardhat build",
    "test": "hardhat test",
    "test:coverage": "hardhat test --coverage",
    "typecheck": "tsc --noEmit",
    "node": "hardhat node",
    "build:shared": "npm run build --workspace @trustmesh/shared",
    "build:sdk": "npm run build --workspace @trustmesh/sdk",
    "build:agents": "npm run build --workspace @trustmesh/agents",
    "build:orchestrator": "npm run build --workspace @trustmesh/orchestrator",
    "build:dashboard": "npm run build --workspace @trustmesh/dashboard",
    "agents": "npm run build:agents && node --env-file=.env apps/agents/dist/cli.js",
    "orchestrator": "npm run build:orchestrator && node --env-file=.env apps/orchestrator/dist/cli.js",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:fuji": "hardhat run scripts/deploy.ts --network fuji",
    "seed:local": "hardhat run scripts/seed.ts --network localhost",
    "seed:fuji": "hardhat run scripts/seed.ts --network fuji",
    "dashboard": "npm run start --workspace @trustmesh/dashboard"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "5.0.7",
    "@types/node": "22.19.11",
    "hardhat": "3.9.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "viem": "2.52.2"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  }
}
