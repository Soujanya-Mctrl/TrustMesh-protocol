{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "paths": {
      "@trustmesh/shared": ["../../packages/shared/dist/index.d.ts"],
      "@trustmesh/shared/*": ["../../packages/shared/dist/*"]
    },
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false
  },
  "include": [
    "src/**/*.ts"
  ]
}